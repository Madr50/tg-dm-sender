[Unit]
Description=Telegram DM Ultra V4
After=network.target
Wants=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/tg-dm-sender
Environment=PYTHONUNBUFFERED=1
Environment=PORT=5000
ExecStart=/usr/bin/python3 /home/ubuntu/tg-dm-sender/app.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tg-dm-sender

# Prevent resource exhaustion
LimitNOFILE=65535
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
